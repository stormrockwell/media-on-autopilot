<?xml version="1.0"?>
<phpunit
	bootstrap="vendor/autoload.php"
	colors="true"
	failOnWarning="true"
	failOnRisky="true">
	<testsuites>
		<testsuite name="unit">
			<directory suffix="Test.php">tests/Unit</directory>
		</testsuite>
	</testsuites>
	<php>
		<const name="ABSPATH" value="/tmp/wordpress/"/>
	</php>
</phpunit>
