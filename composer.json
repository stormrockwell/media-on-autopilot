{
    "name": "stormrockwell/media-on-autopilot",
    "description": "Improves the WordPress media library without being invasive.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": { "php": ">=8.2",
        "deliciousbrains/wp-background-processing": "^1.4" },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^3.0",
        "wp-phpunit/wp-phpunit": "^7.0",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": { "psr-4": { "MediaOnAutopilot\\": "src/" } },
    "autoload-dev": { "psr-4": { "MediaOnAutopilot\\Tests\\": "tests/" } },
    "config": {
        "allow-plugins": { "dealerdirect/phpcodesniffer-composer-installer": true }
    },
    "scripts": {
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit -c phpunit-integration.xml.dist",
        "lint": "phpcs",
        "build:zip": "bash bin/build-zip.sh"
    }
}
